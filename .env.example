# ── CinéSearch — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your actual values for local development.
# The .env file is git-ignored and must NEVER be committed.
#
# In production (Cloud Run), these are set with:
#   gcloud run services update <service-name> --set-env-vars KEY=value

# ── TMDB API Key ──────────────────────────────────────────────────────────────
# Used by the movie_details Cloud Function to fetch poster, cast, overview, etc.
# Get yours at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Google Cloud Project ──────────────────────────────────────────────────────
# Required if running Cloud Functions locally with the Functions Framework.
GOOGLE_CLOUD_PROJECT=ferrous-store-487916-f8

# ── BigQuery Dataset ──────────────────────────────────────────────────────────
# Dataset containing the movies and ratings tables.
BQ_DATASET=ASSIGNEMENT1

# ── Streamlit (optional local dev) ───────────────────────────────────────────
# Base URLs for the Cloud Functions (used by the Streamlit app).
# In production these point to Cloud Run URLs; locally you can use the
# Functions Framework dev server (functions-framework --target=<fn> --port=8080).
MOVIES_SEARCH_URL=https://movies-search-XXXXXXXXXX-XX.a.run.app
MOVIES_AUTOCOMPLETE_URL=https://movies-autocomplete-XXXXXXXXXX-XX.a.run.app
MOVIE_DETAILS_URL=https://movie-details-XXXXXXXXXX-XX.a.run.app
MOVIES_SAMPLE_URL=https://movies-sample-XXXXXXXXXX-XX.a.run.app
